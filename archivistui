Cfg:CreateSection("Toggle UI")
Cfg:CreateKeybind({
    Name="Toggle UI Key", CurrentKeybind="RightShift",
    Callback=function(k)
        Win:SetToggleKey(k)
        Lib:Notify({Title="Keybind Set", Content="UI toggle key → "..k, Duration=3})
    end,
})
Cfg:CreateSection("Named Configs")
Cfg:CreateParagraph({
    Title="Autosave",
    Content="Settings save automatically 2s after any change.\nUse Named Configs to keep multiple presets."
})
local cfgName = "default"
local cfgNameEl = Cfg:CreateInput({
    Name="Config Name", CurrentValue="default",
    PlaceholderText="e.g. pvp, build, default",
    Callback=function(v) cfgName = (v ~= "") and v or "default" end,
})
Cfg:CreateButton({Name="▶  Save Config", Callback=function()
    local name = (cfgNameEl._box and cfgNameEl._box.Text ~= "" and cfgNameEl._box.Text)
                 or (cfgNameEl.CurrentValue ~= "" and cfgNameEl.CurrentValue)
                 or "default"
    cfgName = name
    -- Sync CurrentValue so lazy autosave also uses the right name
    cfgNameEl.CurrentValue = name
    Win:SaveConfiguration(name)
    Lib:Notify({Title="Config Saved", Content="Saved as \""..name.."\"", Duration=3})
    -- Small delay so the file is flushed before we re-scan
    task.delay(0.2, function()
        local newList = Win:ListConfigurations()
        if #newList == 0 then newList = {"(none saved)"} end
        if savedDrop then
            savedDrop:Refresh(newList)
            savedDrop:Set(name)  -- highlight the just-saved config
        end
    end)
end})
Cfg:CreateButton({Name="◀  Load Config", Callback=function()
    local name = (cfgNameEl._box and cfgNameEl._box.Text ~= "" and cfgNameEl._box.Text)
                 or (cfgNameEl.CurrentValue ~= "" and cfgNameEl.CurrentValue)
                 or "default"
    cfgName = name
    Win:LoadConfiguration(name)
    Lib:Notify({Title="Config Loaded", Content="Loaded \""..name.."\"", Duration=3})
end})
local savedList = Win:ListConfigurations()
local savedDrop
if #savedList == 0 then savedList = {"(none saved)"} end
savedDrop = Cfg:CreateDropdown({
    Name="Saved Configs", Options=savedList,
    CurrentOption={savedList[1]}, MultipleOptions=false,
    Callback=function(v)
        local n = type(v)=="table" and v[1] or v
        if n and n ~= "(none saved)" then
            cfgName = n; cfgNameEl:Set(n)
            Win:LoadConfiguration(n)
            Lib:Notify({Title="Loaded", Content="Loaded \""..n.."\"", Duration=3})
        end
    end,
})
Cfg:CreateDivider()
Cfg:CreateSection("Info")
Cfg:CreateParagraph({Title="Keybinds", Content="[Set above] — Toggle UI\nQ (default) — Lock On toggle\n\nSliders autosave with 2s debounce."})
Cfg:CreateParagraph({Title="ESP Notes", Content="Player ESP draws SelectionBox or Highlight around all players. Culled beyond Max Distance."})

Win:LoadConfiguration()

