-- Flat root saves with arc_ prefix — works on every executor without subfolder support
local CFG_PREFIX = "arc_"

local function cfgSave(meta, flags, nameOverride)
    if not (meta and meta.enabled) then return end
    if not writefile then
        warn("Archivist | writefile not available")
        return
    end
    local ok, err = pcall(function()
        local fname = nameOverride or meta.file
        local path  = CFG_PREFIX .. fname .. ".json"
        local data  = {}
        for flag, el in pairs(flags) do
            if     el.CurrentValue   ~= nil then data[flag] = el.CurrentValue
            elseif el.CurrentKeybind ~= nil then data[flag] = el.CurrentKeybind
            elseif el.CurrentOption  ~= nil then data[flag] = el.CurrentOption
            elseif el.CurrentColor   ~= nil then data[flag] = {R=el.CurrentColor.R, G=el.CurrentColor.G, B=el.CurrentColor.B}
            end
        end
        writefile(path, HttpSvc:JSONEncode(data))
    end)
    if not ok then warn("Archivist | cfgSave failed: " .. tostring(err)) end
end

local _saveTicks = {}
local function cfgSaveLazy(meta, flags, nameOverride)
    pcall(function()
        local key = tostring(meta)
        _saveTicks[key] = (_saveTicks[key] or 0) + 1
        local myTick = _saveTicks[key]
        local cb = function() if _saveTicks[key] == myTick then cfgSave(meta, flags, nameOverride) end end
        if task and task.delay then task.delay(2, cb)
        elseif delay then delay(2, cb)
        else task.spawn(function() task.wait(2); cb() end) end
    end)
end

local function cfgLoad(meta, flags, nameOverride)
    if not (meta and meta.enabled) then return end
    if not readfile then
        warn("Archivist | readfile not available")
        return
    end
    local fname = nameOverride or meta.file
    local path  = CFG_PREFIX .. fname .. ".json"
    local raw
    local readOk = pcall(function() raw = readfile(path) end)
    if not readOk or not raw or raw == "" then
        warn("Archivist | No config file at: " .. path)
        return
    end
    local ok, data = pcall(function() return HttpSvc:JSONDecode(raw) end)
    if not ok or not data then
        warn("Archivist | cfgLoad failed to parse: " .. tostring(data))
        return
    end
    for flag, val in pairs(data) do
        local el = flags[flag]
        if el and el.Set then
            local setOk, setErr = pcall(function()
                if type(val) == "table" and val.R then
                    el:Set(Color3.new(val.R, val.G, val.B))
                else
                    el:Set(val)
                end
            end)
            if not setOk then
                warn("Archivist | cfgLoad failed to set flag '" .. flag .. "': " .. tostring(setErr))
            end
        end
    end
end

local function cfgList(meta)
    local out = {}
    if not listfiles then return {"(none saved)"} end
    pcall(function()
        local seen = {}
        local files = {}
        -- Try root paths; image confirms arc_ files live in executor root
        for _, p in ipairs({"", ".", "./"}) do
            local ok, res = pcall(listfiles, p)
            if ok and res and #res > 0 then files = res; break end
        end
        for _, fpath in ipairs(files) do
            local s = tostring(fpath)
            -- Match arc_NAME.json anywhere in the path string
            local name = s:match("[/\\]?"..CFG_PREFIX.."([^/\\]+)%.json$")
                      or s:match("^"..CFG_PREFIX.."([^/\\]+)%.json$")
            if name and not seen[name] then
                seen[name] = true
                table.insert(out, name)
            end
        end
    end)
    return #out > 0 and out or {"(none saved)"}
end

