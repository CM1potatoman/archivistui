    -- Global wheel handler: scrolls contentScroll whenever mouse is inside the window
    UIS.InputChanged:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseWheel then return end
        if not win.Visible then return end
        -- Check mouse is within the window bounds
        local mp  = UIS:GetMouseLocation()
        local ap  = win.AbsolutePosition
        local as  = win.AbsoluteSize
        if mp.X < ap.X or mp.X > ap.X+as.X then return end
        if mp.Y < ap.Y or mp.Y > ap.Y+as.Y then return end
        -- Scroll the content area
        local maxScroll = math.max(0, contentScroll.AbsoluteCanvasSize.Y - contentScroll.AbsoluteSize.Y)
        contentScroll.CanvasPosition = Vector2.new(0,
            math.clamp(contentScroll.CanvasPosition.Y - i.Position.Z * 40, 0, maxScroll))
    end)


