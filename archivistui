function E.Slider(parent, opts, flags, meta)
    local range = opts.Range or {0,100}; local mn, mx = range[1], range[2]
    local incr = opts.Increment or 1; local sfx = opts.Suffix or ""
    local val = math.clamp(opts.CurrentValue or mn, mn, mx)
    local function snap(v) return math.round((v-mn)/incr)*incr+mn end
    local row = mk("Frame", {Size=UDim2.new(1,0,0,50), BackgroundColor3=K.Panel, BorderSizePixel=0, Parent=parent, ClipsDescendants=false})
    lorPanel(row, K.GoldDark)
    mk("TextLabel", {Size=UDim2.new(0.55,0,0,22), Position=UDim2.fromOffset(10,4), BackgroundTransparency=1, Text=opts.Name or "Slider", TextColor3=K.TextGold, TextSize=12, Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, Parent=row})
    local vlbl = mk("TextLabel", {Size=UDim2.new(0.42,0,0,22), Position=UDim2.new(0.55,0,0,4), BackgroundTransparency=1, Text=tostring(val)..(sfx~="" and " "..sfx or ""), TextColor3=K.TextBright, TextSize=11, Font=Enum.Font.GothamBold, TextXAlignment=Enum.TextXAlignment.Right, Parent=row})
    local lp = 12
    local track = mk("Frame", {Size=UDim2.new(1,-lp*2,0,2), Position=UDim2.new(0,lp,0,37), BackgroundColor3=K.GoldDark, BorderSizePixel=0, Parent=row})
    local fill = mk("Frame", {Size=UDim2.new((val-mn)/(mx-mn),0,1,0), BackgroundColor3=K.Gold, BorderSizePixel=0, Parent=track})
    local ksz = 11
    local knob = mk("Frame", {Size=UDim2.fromOffset(ksz,ksz), Position=UDim2.new((val-mn)/(mx-mn),-ksz/2,0.5,-ksz/2), BackgroundColor3=K.GoldBright, BorderSizePixel=0, Rotation=45, ZIndex=4, Parent=track})
    local el = {CurrentValue=val}
    local function set(v)
        v = math.clamp(snap(v), mn, mx); val = v; el.CurrentValue = v
        local t = (v-mn)/(mx-mn)
        tw(fill, {Size=UDim2.new(t,0,1,0)}, 0.07)
        tw(knob, {Position=UDim2.new(t,-ksz/2,0.5,-ksz/2)}, 0.07)
        vlbl.Text = tostring(v)..(sfx~="" and " "..sfx or "")
        if opts.Flag then flags[opts.Flag] = el end; cfgSaveLazy(meta, flags)
        if opts.Callback then task.spawn(opts.Callback, v) end
    end
    el.Set = set
    local drag = false
    local function fromX(x)
        local rel = math.clamp(x - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
        set(mn + (rel/track.AbsoluteSize.X)*(mx-mn))
    end
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true; fromX(i.Position.X) end end)
    knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    UIS.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then fromX(i.Position.X) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    row.MouseEnter:Connect(function() tw(row, {BackgroundColor3=K.PanelHover}, 0.1) end)
    row.MouseLeave:Connect(function() tw(row, {BackgroundColor3=K.Panel}, 0.1) end)
    if opts.Flag then flags[opts.Flag] = el end
    return el
end

function E.Input(parent, opts, flags, meta)
    local row = mk("Frame", {Size=UDim2.new(1,0,0,54), BackgroundColor3=K.Panel, BorderSizePixel=0, Parent=parent})
    lorPanel(row, K.GoldDark)
    mk("TextLabel", {Size=UDim2.new(1,-12,0,20), Position=UDim2.fromOffset(10,4), BackgroundTransparency=1, Text=opts.Name or "Input", TextColor3=K.TextGold, TextSize=12, Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, Parent=row})
    local box = mk("TextBox", {Size=UDim2.new(1,-20,0,24), Position=UDim2.fromOffset(10,26), BackgroundColor3=K.BG, Text=opts.CurrentValue or "", PlaceholderText=opts.PlaceholderText or "", PlaceholderColor3=K.TextDim, TextColor3=K.TextBright, TextSize=12, Font=Enum.Font.Gotham, ClearTextOnFocus=false, Parent=row})
    local bst = stroke(box, K.GoldDark, 1); pad(box, 0, 0, 6, 6)
    box.Focused:Connect(function() tw(bst, {Color=K.Teal}, 0.15) end)
    local el = {CurrentValue=opts.CurrentValue or "", _box=box, Set=function(self, v) box.Text=v; el.CurrentValue=v end}
    box.FocusLost:Connect(function()
        tw(bst, {Color=K.GoldDark}, 0.15)
        if opts.RemoveTextAfterFocusLost then box.Text = "" end
        el.CurrentValue = box.Text
        if opts.Flag then flags[opts.Flag] = el end; cfgSave(meta, flags)
        if opts.Callback then task.spawn(opts.Callback, box.Text) end
    end)
    box:GetPropertyChangedSignal("Text"):Connect(function() el.CurrentValue = box.Text end)
    if opts.Flag then flags[opts.Flag] = el end
    return el
end

-- ═══════════════════════════════════════════════════════
--  DROPDOWN  (v5 — inline expand, pushes content down,
--             no floating, no ZIndex issues)
-- ═══════════════════════════════════════════════════════
function E.Dropdown(parent, opts, flags, meta, guiRoot)
    local sel = type(opts.CurrentOption)=="table" and opts.CurrentOption
                or (opts.CurrentOption and {opts.CurrentOption} or {})
    local multi = opts.MultipleOptions == true
    local open  = false

    local ROW_H    = 30
    local MAX_ROWS = 6  -- rows visible before scrolling

    -- ── Outer wrapper: header + collapsible list in one frame ────
    local wrapper = mk("Frame", {
        Size             = UDim2.new(1,0,0,36),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        ClipsDescendants = false,
        Parent           = parent,
    })

    -- ── Header row ───────────────────────────────────────────────
    local header = mk("Frame", {
        Size             = UDim2.new(1,0,0,36),
        BackgroundColor3 = K.Panel,
        BorderSizePixel  = 0,
        Parent           = wrapper,
    })
    corner(header, 3)
    local wst = lorPanel(header, K.GoldDark)

    mk("TextLabel", {
        Size=UDim2.new(0.55,0,0,36), Position=UDim2.fromOffset(10,0),
        BackgroundTransparency=1, Text=opts.Name or "Dropdown",
        TextColor3=K.TextGold, TextSize=12, Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left, Parent=header,
    })
    local vl = mk("TextLabel", {
        Size=UDim2.new(0.38,0,0,36), Position=UDim2.new(0.55,0,0,0),
        BackgroundTransparency=1,
        Text=#sel>0 and table.concat(sel,", ") or "None",
        TextColor3=K.TextBright, TextSize=11, Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Right,
        TextTruncate=Enum.TextTruncate.AtEnd, Parent=header,
    })
    local arrowLbl = mk("TextLabel", {
        Size=UDim2.fromOffset(16,36), Position=UDim2.new(1,-18,0,0),
        BackgroundTransparency=1, Text="▾",
        TextColor3=K.Gold, TextSize=12, Font=Enum.Font.Gotham,
        Parent=header,
    })

    -- ── List panel (sits directly below header, same parent) ─────
    local listPanel = mk("ScrollingFrame", {
        Size                 = UDim2.new(1,0,0,0),
        Position             = UDim2.fromOffset(0,38),   -- 36px header + 2px gap
        BackgroundColor3     = Color3.fromRGB(8,6,3),
        ClipsDescendants     = true,
        BorderSizePixel      = 0,
        ScrollBarThickness   = 4,
        ScrollBarImageColor3 = K.Gold,
        ScrollingDirection   = Enum.ScrollingDirection.Y,
        CanvasSize           = UDim2.new(0,0,0,0),
        Visible              = false,
        Active               = true,
        Parent               = wrapper,
    })
    stroke(listPanel, K.Gold, 1)
    pad(listPanel, 4, 4, 0, 0)
    list(listPanel, 0)

    -- ── Element ──────────────────────────────────────────────────
    local el = {CurrentOption = sel}
    local optBtns = {}

    local function disp()
        vl.Text = #sel>0 and table.concat(sel,", ") or "None"
    end

    local function setWrapperHeight(extraH)
        -- wrapper height = header + gap + list (or just header when closed)
        wrapper.Size = UDim2.new(1,0,0, 36 + (extraH > 0 and (2 + extraH) or 0))
    end

    local function build()
        for _, b in ipairs(optBtns) do b:Destroy() end
        optBtns = {}
        local optList = opts.Options or {}
        for _, opt in ipairs(optList) do
            local isSel = table.find(sel, opt) ~= nil
            local row = mk("Frame", {
                Size             = UDim2.new(1,0,0,ROW_H),
                BackgroundColor3 = isSel and K.PanelActive or Color3.fromRGB(8,6,3),
                BorderSizePixel  = 0,
                Parent           = listPanel,
            })
            -- teal left accent for selected
            mk("Frame", {
                Size=UDim2.fromOffset(2,ROW_H),
                BackgroundColor3=K.Teal,
                BackgroundTransparency=isSel and 0 or 1,
                BorderSizePixel=0, Parent=row,
            })
            mk("TextLabel", {
                Size=UDim2.new(1,-14,1,0), Position=UDim2.fromOffset(10,0),
                BackgroundTransparency=1, Text=opt,
                TextColor3=isSel and K.TextTeal or K.TextGold,
                TextSize=12,
                Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,
                TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
            })
            mk("Frame", {
                Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
                BackgroundColor3=K.GoldDark, BackgroundTransparency=0.6,
                BorderSizePixel=0, Parent=row,
            })
            local btn = mk("TextButton", {
                Size=UDim2.fromScale(1,1), BackgroundTransparency=1,
                Text="", Parent=row,
            })
            btn.MouseEnter:Connect(function()
                if not isSel then tw(row, {BackgroundColor3=K.PanelHover}, 0.06) end
            end)
            btn.MouseLeave:Connect(function()
                if not isSel then tw(row, {BackgroundColor3=Color3.fromRGB(8,6,3)}, 0.06) end
            end)
            btn.MouseButton1Click:Connect(function()
                if multi then
                    local idx = table.find(sel, opt)
                    if idx then table.remove(sel, idx) else table.insert(sel, opt) end
                else
                    sel = {opt}
                end
                el.CurrentOption = sel; disp(); build()
                if opts.Flag then flags[opts.Flag] = el end
                cfgSave(meta, flags)
                if opts.Callback then
                    task.spawn(opts.Callback, multi and sel or sel[1])
                end
                if not multi then
                    -- close after pick
                    open = false
                    listPanel.Visible = false
                    setWrapperHeight(0)
                    tw(wst, {Color=K.GoldDark}, 0.15)
                    arrowLbl.Text = "▾"
                end
            end)
            table.insert(optBtns, row)
        end
        local contentH = #optList * ROW_H + 8
        local listH    = math.min(contentH, MAX_ROWS * ROW_H + 8)
        listPanel.CanvasSize = UDim2.new(0,0,0,contentH)
        listPanel.Size = UDim2.new(1,0,0,listH)
        setWrapperHeight(listH)
    end

    -- ── Toggle ───────────────────────────────────────────────────
    local function closeList()
        open = false
        listPanel.Visible = false
        setWrapperHeight(0)
        tw(wst, {Color=K.GoldDark}, 0.15)
        arrowLbl.Text = "▾"
    end

    local function openList()
        open = true
        build()
        listPanel.Visible = true
        tw(wst, {Color=K.Gold}, 0.15)
        arrowLbl.Text = "▴"
    end

    mk("TextButton", {
        Size=UDim2.fromScale(1,1), BackgroundTransparency=1,
        Text="", ZIndex=3, Parent=header,
    }).MouseButton1Click:Connect(function()
        if open then closeList() else openList() end
    end)

    header.MouseEnter:Connect(function() tw(header, {BackgroundColor3=K.PanelHover}, 0.1) end)
    header.MouseLeave:Connect(function() tw(header, {BackgroundColor3=K.Panel}, 0.1) end)

    el.Set = function(self, v)
        sel = type(v)=="table" and v or {v}
        el.CurrentOption = sel; disp()
        if open then build() end
    end
    el.Refresh = function(self, newOpts)
        opts.Options = newOpts
        if open then build() end
    end

    if opts.Flag then flags[opts.Flag] = el end
    return el
end

function E.Keybind(parent, opts, flags, meta)
    local key = opts.CurrentKeybind or "None"; local listening = false
    local row = mk("Frame", {Size=UDim2.new(1,0,0,36), BackgroundColor3=K.Panel, BorderSizePixel=0, Parent=parent})
    lorPanel(row, K.GoldDark)
    mk("TextLabel", {Size=UDim2.new(1,-82,1,0), Position=UDim2.fromOffset(10,0), BackgroundTransparency=1, Text=opts.Name or "Keybind", TextColor3=K.TextGold, TextSize=12, Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, Parent=row})
    local function friendlyKey(k)
        local ok, str = pcall(function() return UIS:GetStringForKeyCode(Enum.KeyCode[k]) end)
        return (ok and str and str ~= "") and str or k
    end
    local kb = mk("TextButton", {
        Size=UDim2.fromOffset(70,22), Position=UDim2.new(1,-76,0.5,-11),
        BackgroundColor3=K.BG, Text="["..friendlyKey(key).."]",
        TextColor3=K.TextTeal, TextSize=11, Font=Enum.Font.GothamBold,
        ZIndex=5, Parent=row,
    })
    stroke(kb, K.GoldDark, 1); corner(kb, 2)
    local el = {CurrentKeybind=key}
    el.Set = function(self, k)
        k = tostring(k); key = k; el.CurrentKeybind = k
        kb.Text = "[" .. friendlyKey(k) .. "]"
    end
    kb.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true; kb.Text = "[ ? ]"
        tw(kb, {BackgroundColor3=K.PanelHover}, 0.1)
        local conn
        conn = UIS.InputBegan:Connect(function(i)
            pcall(function()
                local k = ""
                if i.UserInputType == Enum.UserInputType.Keyboard then
                    k = tostring(i.KeyCode):gsub("Enum%.KeyCode%.", "")
                elseif tostring(i.UserInputType):find("MouseButton") then
                    k = tostring(i.UserInputType):gsub("Enum%.UserInputType%.", "")
                end
                if k == "Escape" then
                    listening = false; conn:Disconnect()
                    tw(kb, {BackgroundColor3=K.BG}, 0.1); el:Set(key)
                elseif k ~= "" and k ~= "Unknown" then
                    listening = false; conn:Disconnect()
                    tw(kb, {BackgroundColor3=K.BG}, 0.1); el:Set(k)
                    if opts.Flag then flags[opts.Flag] = el end
                    pcall(cfgSaveLazy, meta, flags)
                    if opts.Callback then pcall(opts.Callback, k) end
                end
            end)
        end)
    end)
    row.MouseEnter:Connect(function() tw(row, {BackgroundColor3=K.PanelHover}, 0.1) end)
    row.MouseLeave:Connect(function() tw(row, {BackgroundColor3=K.Panel}, 0.1) end)
    if opts.Flag then flags[opts.Flag] = el end
    return el
end

function E.ColorPicker(parent, opts, flags, meta)
    local color = opts.Color or Color3.fromRGB(255,255,255)
    local row = mk("Frame", {Size=UDim2.new(1,0,0,36), BackgroundColor3=K.Panel, BorderSizePixel=0, Parent=parent})
    lorPanel(row, K.GoldDark)
    mk("TextLabel", {Size=UDim2.new(1,-92,1,0), Position=UDim2.fromOffset(10,0), BackgroundTransparency=1, Text=opts.Name or "Color", TextColor3=K.TextGold, TextSize=12, Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, Parent=row})
    local sw = mk("Frame", {Size=UDim2.fromOffset(20,14), Position=UDim2.new(1,-26,0.5,-7), BackgroundColor3=color, BorderSizePixel=0, Parent=row})
    stroke(sw, K.GoldDark, 1)
    local hb = mk("TextBox", {Size=UDim2.fromOffset(62,20), Position=UDim2.new(1,-90,0.5,-10), BackgroundColor3=K.BG, Text=string.format("#%02X%02X%02X", math.round(color.R*255), math.round(color.G*255), math.round(color.B*255)), TextColor3=K.TextTeal, TextSize=10, Font=Enum.Font.Code, ClearTextOnFocus=false, Parent=row})
    stroke(hb, K.GoldDark, 1); pad(hb, 0, 0, 4, 4)
    local el = {CurrentColor=color}
    el.Set = function(self, c)
        color = c; el.CurrentColor = c; sw.BackgroundColor3 = c
        hb.Text = string.format("#%02X%02X%02X", math.round(c.R*255), math.round(c.G*255), math.round(c.B*255))
        if opts.Callback then task.spawn(opts.Callback, c) end
    end
    hb.FocusLost:Connect(function()
        local h = hb.Text:gsub("#","")
        if #h==6 then
            local r,g,b = tonumber(h:sub(1,2),16), tonumber(h:sub(3,4),16), tonumber(h:sub(5,6),16)
            if r and g and b then el:Set(Color3.fromRGB(r,g,b)) end
        end
        if opts.Flag then flags[opts.Flag] = el end; cfgSave(meta, flags)
    end)
    row.MouseEnter:Connect(function() tw(row, {BackgroundColor3=K.PanelHover}, 0.1) end)
    row.MouseLeave:Connect(function() tw(row, {BackgroundColor3=K.Panel}, 0.1) end)
    if opts.Flag then flags[opts.Flag] = el end
    return el
end

