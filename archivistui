function E.Toggle(parent, opts, flags, meta)
    local val = opts.CurrentValue == true
    local row = mk("Frame", {Size=UDim2.new(1,0,0,38), BackgroundColor3=K.Panel, BorderSizePixel=0, Parent=parent, ClipsDescendants=false})
    local rst = lorPanel(row, val and K.TealDim or K.GoldDark)
    local bar = mk("Frame", {Size=UDim2.new(0,2,1,0), BackgroundColor3=K.Teal, BackgroundTransparency=val and 0 or 1, BorderSizePixel=0, ZIndex=3, Parent=row})
    local lbl = mk("TextLabel", {Size=UDim2.new(1,-56,1,0), Position=UDim2.fromOffset(10,0), BackgroundTransparency=1, Text=opts.Name or "Toggle", TextColor3=val and K.TextBright or K.TextGold, TextSize=12, Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, Parent=row})
    local track = mk("Frame", {Size=UDim2.fromOffset(38,18), Position=UDim2.new(1,-48,0.5,-9), BackgroundColor3=val and K.TealDim or K.BG, BorderSizePixel=0, Parent=row})
    corner(track, 9)
    local tst = stroke(track, val and K.Teal or K.GoldDark, 1)
    local knob = mk("Frame", {Size=UDim2.fromOffset(12,12), Position=UDim2.new(val and 1 or 0, val and -14 or 3, 0.5, -6), BackgroundColor3=val and K.Teal or K.TextGold, BorderSizePixel=0, Parent=track})
    corner(knob, 6)
    local el = {CurrentValue=val}
    local function set(v)
        val = v; el.CurrentValue = v
        tw(track, {BackgroundColor3=v and K.TealDim or K.BG}, 0.15)
        tw(tst, {Color=v and K.Teal or K.GoldDark}, 0.15)
        tw(knob, {Position=UDim2.new(v and 1 or 0, v and -14 or 3, 0.5, -6), BackgroundColor3=v and K.Teal or K.TextGold}, 0.15)
        tw(bar, {BackgroundTransparency=v and 0 or 1}, 0.15)
        tw(rst, {Color=v and K.TealDim or K.GoldDark}, 0.15)
        lbl.TextColor3 = v and K.TextBright or K.TextGold
        if opts.Flag then flags[opts.Flag] = el end; cfgSaveLazy(meta, flags)
        if opts.Callback then task.spawn(opts.Callback, v) end
    end
    el.Set = set
    mk("TextButton", {Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text="", Parent=row}).MouseButton1Click:Connect(function() set(not val) end)
    row.MouseEnter:Connect(function() tw(row, {BackgroundColor3=K.PanelHover}, 0.1) end)
    row.MouseLeave:Connect(function() tw(row, {BackgroundColor3=K.Panel}, 0.1) end)
    if opts.Flag then flags[opts.Flag] = el end
    return el
end

