-- ─────────────────────────────────────────────────────────
--  LOCK ON
-- ─────────────────────────────────────────────────────────
local LockState = {
    enabled=false, fov=90, smooth=10, part="Head",
    sort="FOV", key="Q", predict=false, predScale=3,
}
local lockedTarget = nil
local lockConn     = nil

local function lockGetBest()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local best, bestScore = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local part = p.Character:FindFirstChild(LockState.part)
                      or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local fovD = (Vector2.new(sp.X,sp.Y) - center).Magnitude
                    local wldD = (Camera.CFrame.Position - part.Position).Magnitude
                    local hum  = p.Character:FindFirstChildOfClass("Humanoid")
                    local hp   = hum and hum.Health or 100
                    local score = LockState.sort=="Distance" and wldD
                               or LockState.sort=="Health"   and hp
                               or fovD
                    if fovD <= LockState.fov and score < bestScore then
                        bestScore = score; best = part
                    end
                end
            end
        end
    end
    return best
end

local function lockStart()
    lockedTarget = lockGetBest()
    if not lockedTarget then return end
    lockConn = RunSvc.RenderStepped:Connect(function(dt)
        if not lockedTarget or not lockedTarget.Parent then
            lockedTarget = nil; lockConn:Disconnect(); lockConn = nil; return
        end
        local pos = lockedTarget.Position
        if LockState.predict then
            local vel = lockedTarget.AssemblyLinearVelocity or Vector3.zero
            pos = pos + vel * (dt * LockState.predScale)
        end
        local cur  = Camera.CFrame
        local goal = CFrame.lookAt(cur.Position, pos)
        local alpha = math.clamp(dt * (61 - LockState.smooth), 0, 1)
        Camera.CFrame = cur:Lerp(goal, alpha)
    end)
end

local function lockStop()
    lockedTarget = nil
    if lockConn then lockConn:Disconnect(); lockConn = nil end
end

UIS.InputBegan:Connect(function(i)
    if not LockState.enabled then return end
    if i.UserInputType == Enum.UserInputType.Keyboard then
        local k = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
        if k == LockState.key then
            if lockedTarget then lockStop() else lockStart() end
        end
    end
end)

