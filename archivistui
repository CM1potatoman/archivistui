local function tw(o, p, t, s, d)
    Tween:Create(o, TweenInfo.new(t or .15, s or Enum.EasingStyle.Quad, d or Enum.EasingDirection.Out), p):Play()
end

local function mk(cls, props)
    local i = Instance.new(cls)
    for k, v in pairs(props) do if k ~= "Parent" then i[k] = v end end
    if props.Parent then i.Parent = props.Parent end
    return i
end

local function stroke(p, col, thick, trans)
    return mk("UIStroke", {Color=col, Thickness=thick or 1, Transparency=trans or 0, Parent=p})
end

local function corner(p, r)
    return mk("UICorner", {CornerRadius=UDim.new(0, r or 2), Parent=p})
end

local function pad(p, t, b, l, r)
    return mk("UIPadding", {
        PaddingTop=UDim.new(0,t or 0), PaddingBottom=UDim.new(0,b or 0),
        PaddingLeft=UDim.new(0,l or 0), PaddingRight=UDim.new(0,r or 0), Parent=p
    })
end

local function list(p, gap, dir, ha)
    return mk("UIListLayout", {
        Padding=UDim.new(0, gap or 4),
        FillDirection=dir or Enum.FillDirection.Vertical,
        HorizontalAlignment=ha or Enum.HorizontalAlignment.Left,
        SortOrder=Enum.SortOrder.LayoutOrder, Parent=p
    })
end



local function brackets(f, col, sz)
    col = col or K.GoldBright; sz = sz or 8
    for _, ax in ipairs({0, 1}) do for _, ay in ipairs({0, 1}) do
        mk("Frame", {Size=UDim2.fromOffset(sz,1),  Position=UDim2.new(ax,ax==0 and 0 or -sz, ay, ay==0 and 0 or -1),  BackgroundColor3=col, BorderSizePixel=0, ZIndex=f.ZIndex+3, Parent=f})
        mk("Frame", {Size=UDim2.fromOffset(1, sz), Position=UDim2.new(ax,ax==0 and 0 or -1,  ay, ay==0 and 0 or -sz), BackgroundColor3=col, BorderSizePixel=0, ZIndex=f.ZIndex+3, Parent=f})
    end end
end

local function lorPanel(f, col, thick)
    f.BorderSizePixel = 0
    local st = stroke(f, col or K.Gold, thick or 1)
    brackets(f, K.GoldBright)
    return st
end

local function draggable(frame, handle)
    local down, ds, dp = false
    handle = handle or frame
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            down = true; ds = i.Position; dp = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then down = false end
    end)
    UIS.InputChanged:Connect(function(i)
        if down and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - ds
            frame.Position = UDim2.new(dp.X.Scale, dp.X.Offset+d.X, dp.Y.Scale, dp.Y.Offset+d.Y)
        end
    end)
end

