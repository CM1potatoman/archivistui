    local camPos = Camera.CFrame.Position
    for char, objs in pairs(espObjs) do
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            local dist = math.round((camPos - root.Position).Magnitude)
            local cull = dist > ESPState.maxDist
            for _, o in ipairs(objs) do
                if o:IsA("SelectionBox") or o:IsA("Highlight") then
                    o.Enabled = not cull
                elseif o:IsA("BillboardGui") then
                    o.Enabled = not cull
                    local dl = o:FindFirstChild("DistLabel")
