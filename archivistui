local function espAdd(player)
    if player == LP then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if ESPState.team=="Enemies Only" and player.Team==LP.Team then return end
    if ESPState.team=="Allies Only"  and player.Team~=LP.Team then return end
    espRemove(char)
    local objs = {}
    if ESPState.mode=="Box" or ESPState.mode=="Corner Box" then
        table.insert(objs, espMakeBox(char))
    elseif ESPState.mode=="Highlight" then
        table.insert(objs, espMakeHighlight(char))
    end
    local bb = espMakeBillboard(root)
    local nl = bb:FindFirstChild("NameLabel")
    if nl then nl.Text = ESPState.names and player.DisplayName or "" end
    table.insert(objs, bb)
    espObjs[char] = objs
    char.AncestryChanged:Connect(function() espRemove(char) end)
end

